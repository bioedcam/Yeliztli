{
  "name": "frontend",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "bash -c 'set -o pipefail; vitest run 2>&1 | tee /tmp/vitest.log; VITEST_EXIT=$?; grep -q \"not wrapped in act\" /tmp/vitest.log && exit 1; exit $VITEST_EXIT'"
  },
  "dependencies": {
