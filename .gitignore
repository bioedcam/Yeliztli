# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Node / Frontend
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# SQLite databases (runtime data)
*.db
*.db-wal
*.db-shm
# Exception: test fixtures and bundled databases
!tests/fixtures/*.db
!bundles/*.db

# Environment & secrets
.env
.env.*
credentials.json

# OS
.DS_Store
Thumbs.db

# Yeliztli runtime data (not curated panels)
data/
!backend/data/
!backend/data/**
# ...but never the build artifacts the broad negation above would otherwise re-include
backend/data/**/__pycache__/
downloads/
.yeliztli/
logs/

# Coverage & test artifacts
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
# Stringified MagicMock leaks (defense-in-depth — fix the test, but don't commit the artifact)
<MagicMock*

# Playwright
test-results/
playwright-report/
blob-report/

# Claude
.claude/

# Review/planning docs (local only — kept on disk, never committed)
gero.md
/amv2.md
/stup.md
/prd.md
/Yeliztli_Spec.md
/docs/AncestryDNA_Implementation_Steps.md
/docs/AncestryDNA_Integration_Plan.md
/docs/bundle-v2.0.0-build-plan.md
/docs/bundle-v2.0.0-implementation-steps.md

# Real user genotype exports — never commit (privacy + size)
AncestryDNA.txt
AncestryDNA.txt:Zone.Identifier
AncestryDNAsample.txt
AncestryDNAsample.txt:Zone.Identifier

# LAI bundle artifacts — distributed via GitHub Releases, not git.
# Keep the legacy genomeinsight_lai_bundle_* pattern alongside the yeliztli_ one: the
# currently-published asset is still named genomeinsight_lai_bundle_* (immutable), so
# existing dev-machine artifacts must stay ignored through the deprecation window.
genomeinsight_lai_bundle_*.tar.gz
yeliztli_lai_bundle_*.tar.gz
lai_bundle_build/
